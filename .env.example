## Omni (partners) — REQUIRED for Omni tool calls
OMNI_API_KEY=
OMNI_BASE_URL=https://partners.omniapp.co/api
OMNI_MODEL_ID=

## Gemini coordinator — REQUIRED to enable POST /api/chat
## Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

## Optional: use Vertex AI instead of AI Studio key
## GEMINI_PROVIDER=vertex
## GEMINI_VERTEX_PROJECT=your-gcp-project
## GEMINI_VERTEX_LOCATION=us-central1

## Google Calendar OAuth (prototype)
## Create OAuth Web Client in Google Cloud Console and set redirect URI:
## http://localhost:3000/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

